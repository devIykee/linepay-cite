# ──────────────────────────────────────────────────────────────────────────
# LinePay Cite — environment configuration
# Copy to .env (root) and apps/web/.env.local. Everything works in SIMULATE
# mode out of the box; fill the live values only when you go on-chain.
# ──────────────────────────────────────────────────────────────────────────

# ── Payments mode ──────────────────────────────────────────────────────────
# "simulate" (default) settles in a local ledger — no keys, no network.
# "live" signs authorizations and settles real USDC via Circle Gateway on Arc.
PAYMENTS_MODE=simulate

# ── Arc testnet (live mode) ────────────────────────────────────────────────
# Provision with the ARC CLI:  arc network use testnet  &&  arc account create
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=13371
USDC_ADDRESS=0x0000000000000000000000000000000000000000

# ── Circle Gateway / Agent Stack (live mode) ───────────────────────────────
CIRCLE_GATEWAY_URL=https://gateway.circle.com/v1
CIRCLE_API_KEY=
# Buyer agent wallet (Circle Agent Stack). Funded with testnet USDC.
AGENT_WALLET_ADDRESS=0xA9ENT0000000000000000000000000000000000
AGENT_WALLET_PRIVATE_KEY=

# ── Revenue split contract (optional; falls back to direct creator pay) ─────
REVENUE_SPLIT_ADDRESS=
PLATFORM_ADDRESS=0xP1A7F0RM00000000000000000000000000000000
REFERRER_ADDRESS=0xREFERRER000000000000000000000000000000000

# ── Anthropic (buyer agent reasoning) ──────────────────────────────────────
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-8

# ── App ────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
DATABASE_PATH=./linepay.db
