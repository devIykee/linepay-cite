# ──────────────────────────────────────────────────────────────────────────
# LinePay Cite — environment configuration
#
# ⚠️  TESTNET ONLY. Every contract/address here targets Circle's Arc TESTNET.
#     All USDC is TEST USDC with no real-world value. Never point at mainnet.
#
# Copy to .env (root) and apps/web/.env.local. Fill secrets only where needed.
# NEVER commit real secrets — only this .env.example (all-empty) is tracked.
# ──────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # canonical public origin (CORS, URLs)
APP_BASE_URL=http://localhost:3000          # server/agent base URL
# "simulate" (default) auto-approves payments + finalizes ledger immediately.
# "live" requires real Circle Gateway settlement + webhook confirmation.
PAYMENTS_MODE=simulate

# ── Database (Postgres) ────────────────────────────────────────────────────
# Local docker:  postgres://postgres:postgres@localhost:5432/linepay
# Supabase: use the IPv4 *Session pooler* string (Dashboard → Connect):
#   postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=
# PGSSL=require to force TLS (managed hosts auto-enable it); PGSSL=disable for local.
PGSSL=

# ── Auth (NextAuth / Auth.js) ──────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Google OAuth (required) — console.cloud.google.com → Credentials → OAuth client.
# Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth (second provider) — github.com/settings/developers.
# Callback URL: <NEXT_PUBLIC_APP_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Logins matching this email are auto-promoted to role 'admin' on first sign-in.
ADMIN_EMAIL=

# ── Arc testnet ────────────────────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_NETWORK_CAIP2=eip155:5042002
USDC_ADDRESS=0x3600000000000000000000000000000000000000   # ERC-20 USDC on Arc testnet (6 decimals)

# ── Circle Gateway / payments ──────────────────────────────────────────────
CIRCLE_API_KEY=                                            # Circle developer API key (keep secret)
CIRCLE_GATEWAY_URL=https://gateway-api-testnet.circle.com  # x402 settle host
# GatewayWalletBatched contract (EIP-712 verifyingContract; where agents pay).
CIRCLE_GATEWAY_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9   # back-compat alias
# HMAC secret from the Circle dashboard used to verify incoming webhooks.
CIRCLE_WEBHOOK_SECRET=
# Where the platform's cut accrues / is swept to.
PLATFORM_WALLET_ADDRESS=
# Default per-block price advertised in /.well-known (creators override per piece).
DEFAULT_PRICE_PER_BLOCK=0.05

# Buyer agent wallet (funded with test USDC for live agent payments).
BUYER_ADDRESS=
BUYER_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=                                      # back-compat alias
AGENT_WALLET_PRIVATE_KEY=

# ── Revenue split (server-side; creator cut is always the remainder) ───────
PLATFORM_FEE_RATE=0.10        # platform cut
REFERRER_FEE_RATE=0.05        # referrer cut (only applied when a referrer exists)
# (Do NOT define CREATOR_FEE_RATE — the creator's share is the remainder.)

# ── Email (transactional) ──────────────────────────────────────────────────
# Resend is the default; Postmark is the fallback. All sends are async.
RESEND_API_KEY=
POSTMARK_API_KEY=
EMAIL_FROM=noreply@yourapp.com

# ── Rate limiting (Upstash Redis; falls back to in-memory if unset) ────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_IMPORT=10
RATE_LIMIT_AGENT_READ=60
RATE_LIMIT_WEBHOOK=200
RATE_LIMIT_ADMIN_SSE=5
RATE_LIMIT_AUTH=20
RATE_LIMIT_SEARCH=30

# ── Browser-exposed (NEXT_PUBLIC_*) ────────────────────────────────────────
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_WC_PROJECT_ID=        # WalletConnect id — cloud.reown.com (silences 403s)
NEXT_PUBLIC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# ── Agent reasoning (optional LLM for the legacy research flow) ─────────────
AGENT_PROVIDER=                   # groq | anthropic (auto-detected from keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-8
